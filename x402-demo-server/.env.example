# x402 Resource Server Configuration
# Algorand TestNet - hosted GoPlausible facilitator

# Your resource server receiving address (for USDC payments)
# See: https://dev.algorand.co/concepts/accounts/create/
AVM_ADDRESS=

# Hosted Facilitator URL (use GoPlausible by default)
FACILITATOR_URL=https://facilitator.goplausible.xyz

# Server port
PORT=4021

# Groq API Key for classify-task route LLM calls
GROQ_API_KEY=

# MongoDB URI (Atlas or local) and Database Name
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=prism_app

# JWT secret keys for access and refresh tokens
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

